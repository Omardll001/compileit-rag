OPENAI_API_KEY=sk-...
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Crawler
SITE_BASE_URL=https://compileit.com
CRAWL_MAX_PAGES=100
CRAWL_MAX_DEPTH=2

# Vector store
CHROMA_PERSIST_DIR=./chroma_db
CHROMA_COLLECTION=compileit

# Retrieval
RETRIEVAL_K=5
RETRIEVAL_FETCH_K=20

# CORS
ALLOWED_ORIGINS=http://localhost:3000
